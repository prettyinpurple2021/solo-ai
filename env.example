# SoloSuccess AI - Environment Configuration Template
#
# EASIEST SETUP: copy this file to .env.local in the PROJECT ROOT (next to README.md).
# Then run: npm run dev:all
#
# Next.js reads root .env* automatically. The API loads root .env / .env.local via server/env-load.ts.
# You do not need duplicate server/.env* files unless you want API-only overrides.
#
# Step-by-step: README.md → "Local development (simple)".
# Production: Vercel (Next.js) + Railway (Express API in server/).
# WHERE EACH VARIABLE GOES (read this): docs/deployment/ENV_VARS_VERCEL_AND_RAILWAY.md
# NEXT_PUBLIC_SOCKET_URL on Vercel = your Railway API base URL (https://…, no path).
#
# 🌐 BASE URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_SOCKET_URL="http://localhost:5000"

# 🗄️ DATABASE (PostgreSQL - Neon recommended)
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# 🔑 AUTHENTICATION
JWT_SECRET="your-at-least-32-char-secret-key-here"
# NextAuth v5 also reads AUTH_SECRET (32+ chars). Run: npx auth secret
AUTH_SECRET=""
NEXTAUTH_SECRET="your-next-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# OAuth (optional — Google / GitHub sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# 📚 STACK AUTH (Alternative to NextAuth)
NEXT_PUBLIC_STACK_PROJECT_ID=""
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=""
STACK_SECRET_SERVER_KEY=""

# 🤖 AI PROVIDERS
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
GOOGLE_AI_API_KEY=""
# Google GenAI on the Express server (routes under server/) — often same key as above
GEMINI_API_KEY=""

# 💳 BILLING - STRIPE
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# STRIPE PRICE IDS (Monthly)
STRIPE_ACCELERATOR_PRICE_ID=""
STRIPE_DOMINATOR_PRICE_ID=""

# STRIPE PRICE IDS (Yearly)
STRIPE_ACCELERATOR_YEARLY_PRICE_ID=""
STRIPE_DOMINATOR_YEARLY_PRICE_ID=""

# 💰 BILLING - PAYPAL
PAYPAL_MODE="sandbox" # or 'live'
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# 📧 EMAIL (Resend)
RESEND_API_KEY=""
FROM_EMAIL="SoloSuccess AI <support@solosuccesss.com>"

# 🔔 PUSH NOTIFICATIONS (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_CONTACT_EMAIL="support@solosuccesss.com"

# 🛡️ SECURITY - RECAPTCHA ENTERPRISE
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
NEXT_PUBLIC_RECAPTCHA_PROJECT_ID=""
RECAPTCHA_SECRET_KEY=""
GOOGLE_CLOUD_PROJECT_ID=""
GOOGLE_CLOUD_API_KEY=""

# 📊 ANALYTICS
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_AMPLITUDE_API_KEY=""
LOG_INGEST_URL=""

# ⚡ UPSTASH (Redis & QStash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
QSTASH_URL=""
QSTASH_TOKEN=""
QSTASH_NEXT_SIGNING_KEY=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_ONBOARDING_CALLBACK_URL=""
QSTASH_WORKER_CALLBACK_URL=""

# 🛠️ FEATURE FLAGS & CAPS
ENABLE_AGENT_MESSAGE_PUMP="true"
ENABLE_NOTIFICATION_PROCESSOR="true"
VALIDATE_ENV="true"
NOTIF_DAILY_CAP="500"
SCRAPING_USER_HOURLY_CAP="20"
FEATURE_ENABLE_NOTIFICATIONS="true"
FEATURE_ENABLE_SCRAPING="true"

# 📱 MOBILE / PWA
NEXT_PUBLIC_PERFORMANCE_MONITOR="false"
NEXT_PUBLIC_DISABLE_EXIT_INTENT="false"

# 🧪 TESTING
TEST_USER_EMAIL="test@example.com"
TEST_USER_PASSWORD="password123"
INTERNAL_API_KEY="your-internal-api-key"
INTERNAL_AGENT_SECRET="your-agent-secret"
ENCRYPTION_KEY=""

# 🔧 OTHER (optional)
ADMIN_EMAILS=""
ADMIN_EMAIL=""
BRAVE_API_KEY=""
NOTIFICATION_JOB_TOKEN=""
NEXT_PUBLIC_USE_BACKEND_STORAGE="true"
SENTRY_DSN=""
DEBUG_SERVER_LOGS="0"
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
TWITTER_API_KEY=""
TWITTER_API_SECRET=""
