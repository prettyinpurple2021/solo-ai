{
  "name": "solosuccess-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "npm run validate && cross-env NODE_OPTIONS='--max-old-space-size=16384' next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "validate": "npm run lint && npm run type-check",
    "type-check": "concurrently \"npm run type-check:web\" \"npm run type-check:server\"",
    "type-check:web": "cross-env NODE_OPTIONS='--max-old-space-size=16384' tsc --noEmit -p tsconfig.json",
    "type-check:server": "cd server && tsc --noEmit -p tsconfig.json",
    "internal:docs": "ts-node scripts/internal/doc-maintainer.ts",
    "internal:audit": "ts-node scripts/internal/launch-readiness.ts",
    "internal:features": "ts-node scripts/internal/feature-inventory.ts",
    "dev:all": "concurrently \"npm run dev\" \"cd server && npm run dev\"",
    "start:all": "concurrently \"npm run start\" \"cd server && npm run start\"",
    "db:generate": "drizzle-kit generate --config=server/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=server/drizzle.config.ts",
    "db:apply-api-baseline": "node scripts/apply-api-tables-baseline.mjs",
    "db:studio": "drizzle-kit studio --config=server/drizzle.config.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
