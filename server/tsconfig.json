{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "../src/*"
            ],
            "@/server/*": [
                "./*"
            ],
            "@/shared/*": [
                "../src/lib/shared/*"
            ],
            "drizzle-orm": [
                "./node_modules/drizzle-orm"
            ],
            "drizzle-orm/*": [
                "./node_modules/drizzle-orm/*"
            ],
            "zod": [
                "./node_modules/zod"
            ]
        }
    },
    "include": [
        "./**/*.ts",
        "../src/lib/shared/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "../src/**/*.test.ts"
    ]
}