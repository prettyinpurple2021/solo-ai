# Optional overrides when running the API from the server/ folder.
# Production API is deployed to Railway (see docs/deployment/RAILWAY_CONNECT.md and README).
# For most people: use only the PROJECT ROOT .env.local (see ../env.example and README.md).
# server/env-load.ts loads root .env and .env.local before these.
#
# This file is a convenience subset, not an exhaustive inventory — see ../env.example for
# every variable the monorepo may read (Next.js + Express + workers).

GEMINI_API_KEY=PLACEHOLDER_API_KEY

# Database URL (if different from root)
DATABASE_URL='postgresql://username:password@host:5432/database?sslmode=require'

# Server port (Express default is 5000 if unset)
PORT=5000

# Upstash Redis (Required for Usage Tracking & Caching)
UPSTASH_REDIS_REST_URL="your-upstash-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"


# Client URL (Frontend)
CLIENT_URL="http://localhost:3000"

# OpenAI API Key (Required for some agents)
OPENAI_API_KEY="sk-..."

# Stripe Configuration (tier IDs in DB/app: free, launch, accelerator, dominator — not solo/pro/agency)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_ACCELERATOR_PRICE_ID="price_..."
STRIPE_DOMINATOR_PRICE_ID="price_..."
# Optional yearly checkout (see src/lib/pricing.ts)
# STRIPE_ACCELERATOR_YEARLY_PRICE_ID="price_..."
# STRIPE_DOMINATOR_YEARLY_PRICE_ID="price_..."

# JWT Secret (for auth tokens)
JWT_SECRET="your-secret-key-change-in-production"

# Node Environment
# NODE_ENV="development"

# Optional observability
# SENTRY_DSN=""
# DEBUG_SERVER_LOGS="0"
